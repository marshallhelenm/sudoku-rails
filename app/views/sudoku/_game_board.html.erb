<%# locals: {puzzle:} %>
<%= turbo_frame_tag "game_board" do %>
    <% if @failed_puzzle %>
        <h3>Failed Puzzle:</h3>
    <% end %>
    <div class="board" >
        <% puzzle.rows.values.each do |row| %>
            <% row.cells.each do |cell| %>
                <%= render "sudoku/cell_square", value: cell.value, ci: cell.ci, cj: cell.cj, options: cell.options %>
            <% end %>
        <% end %>
    </div>
<% end %>
