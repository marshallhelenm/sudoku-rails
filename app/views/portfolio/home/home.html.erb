<% content_for :title, "El Marshall" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "fullpage", media: "all" %>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <%= javascript_include_tag "jquery.fullPage" %>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- Added for mobile responsiveness -->
<% end %>

<% content_for :page_styles do %>
  <%= stylesheet_link_tag "portfolio", media: "all" %>
<% end %>

<div class="panel" id="fullpage">
  <%= render "portfolio/home/name_card" %>
  <%= render "portfolio/home/projects" %>
  <%= render "portfolio/home/attributions" %>
</div>
